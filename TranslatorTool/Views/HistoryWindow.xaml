<Window x:Class="TranslatorTool.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史记录"
        Height="460"
        Width="860"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Padding="12,6" Margin="0,0,8,0" Content="刷新" Command="{Binding RefreshCommand}" />
            <Button Padding="12,6" Margin="0,0,8,0" Content="复制译文" Command="{Binding CopyTranslationCommand}" />
            <Button Padding="12,6" Content="清空历史" Command="{Binding ClearCommand}" />
        </StackPanel>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusMessage}" />
        </StatusBar>

        <DataGrid ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150" />
                <DataGridTextColumn Header="来源" Binding="{Binding TriggerSource}" Width="130" />
                <DataGridTextColumn Header="引擎" Binding="{Binding Engine}" Width="80" />
                <DataGridTextColumn Header="原文" Binding="{Binding SourceText}" Width="2*" />
                <DataGridTextColumn Header="译文" Binding="{Binding TranslatedText}" Width="2*" />
                <DataGridTextColumn Header="注释" Binding="{Binding Notes}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
