<Window x:Class="TranslatorTool.Views.ScreenshotOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#55000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp">
    <Canvas x:Name="SelectionCanvas">
        <Rectangle x:Name="SelectionRectangle"
                   Stroke="#FF2F80ED"
                   StrokeThickness="2"
                   Fill="#332F80ED"
                   Visibility="Collapsed" />
        <TextBlock Canvas.Left="18" Canvas.Top="18"
                   Text="拖动选择截图区域，按 ESC 取消"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="SemiBold" />
    </Canvas>
</Window>
