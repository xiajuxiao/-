<Window x:Class="TranslatorTool.Views.FloatingTranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="翻译结果"
        Width="520"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#FFFDFDFD" BorderBrush="#FFD6D6D6" BorderThickness="1" CornerRadius="8" Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.22" />
        </Border.Effect>

        <Grid MaxHeight="720">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="14,10,14,8" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="翻译结果" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                <Button Grid.Column="1" Width="28" Height="24" Content="X" Click="CloseButton_Click" />
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#FFD0D0D0" />

            <Border Grid.Row="2" Margin="14,10,14,0" Padding="8,6" Background="#FFF7F7F7" BorderBrush="#FFE2E2E2" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusMessage}"
                               Foreground="#FF444444"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Width="24"
                            Height="22"
                            Margin="8,0,0,0"
                            Padding="0"
                            Content="&#x21BB;"
                            FontSize="14"
                            ToolTip="重新请求在线翻译"
                            Command="{Binding RefreshOnlineCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnlineRefreshVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="3" Margin="14,10,14,0" MaxHeight="390" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBox x:Name="SourceTextBox"
                             Text="{Binding SourceText, Mode=OneWay}"
                             FontSize="14"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Cursor="IBeam"
                             SelectionChanged="SelectableTextBox_SelectionChanged"
                             MouseLeftButtonUp="SelectableTextBox_MouseLeftButtonUp" />
                    <TextBlock Margin="0,10,0,0" Text="翻译:" FontWeight="SemiBold" />
                    <TextBox x:Name="TranslatedTextBox"
                             Text="{Binding TranslatedText, Mode=OneWay}"
                             FontSize="17"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Cursor="IBeam"
                             SelectionChanged="SelectableTextBox_SelectionChanged"
                             MouseLeftButtonUp="SelectableTextBox_MouseLeftButtonUp" />
                </StackPanel>
            </ScrollViewer>

            <ItemsControl Grid.Row="4" Margin="14,10,14,0" ItemsSource="{Binding Phonetics}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock TextWrapping="Wrap">
                            <Run Text="{Binding Word}" FontWeight="SemiBold" />
                            <Run Text=" " />
                            <Run Text="{Binding AmericanPhonetic}" />
                            <Run Text=" " />
                            <Run Text="{Binding Meaning}" Foreground="#FF555555" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="5" Margin="14,10,14,0">
                <TextBlock Text="注释:" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Notes}" TextWrapping="Wrap" Foreground="#FF444444" />
                <TextBlock Margin="0,8,0,0" Text="{Binding SourceDisplay}" Foreground="#FF666666" />
            </StackPanel>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="14,12,14,14">
                <Button Padding="12,5" Margin="0,0,8,0" Content="朗读" Command="{Binding SpeakCommand}" />
                <Button Padding="12,5" Content="复制" Command="{Binding CopyCommand}" />
            </StackPanel>

            <Popup x:Name="WordPopup"
                   Placement="MousePoint"
                   AllowsTransparency="True"
                   StaysOpen="True">
                <Border Background="#FFFFFFFF"
                        BorderBrush="#FFBEBEBE"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        MouseLeave="WordPopup_MouseLeave">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.2" />
                    </Border.Effect>
                    <StackPanel MinWidth="180" MaxWidth="260">
                        <TextBlock x:Name="PopupWordText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock x:Name="PopupPhoneticText" Margin="0,4,0,0" Foreground="#FF555555" TextWrapping="Wrap" />
                        <TextBlock x:Name="PopupTranslationText" Margin="0,6,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <Button Margin="0,10,0,0"
                                Padding="10,4"
                                HorizontalAlignment="Right"
                                Content="朗读"
                                Click="PopupSpeakButton_Click" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
