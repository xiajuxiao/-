<Window x:Class="TranslatorTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="窗口翻译工具" Height="180" Width="360"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <StackPanel>
            <TextBlock Text="窗口翻译工具正在后台运行" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Margin="0,10,0,0" Text="使用 Alt + Q 截图翻译，或通过托盘菜单打开功能。" TextWrapping="Wrap" />
            <Button Margin="0,18,0,0" Padding="12,6" HorizontalAlignment="Left" Content="隐藏窗口" Click="HideButton_Click" />
        </StackPanel>
    </Grid>
</Window>
